# Easy Data 环境变量示例
# 复制为 .env 后按需修改：cp .env.example .env

# ---------- 应用 ----------
# APP_NAME=Easy Data
# APP_VERSION=1.0.0
# DEBUG=true

# ---------- 数据库 ----------
# 本地开发默认 SQLite（相对 backend 或当前目录）
DATABASE_URL=sqlite:///./easy_data.db
# Docker 持久化：使用挂载目录，例如 DATABASE_URL=sqlite:////app/data/easy_data.db 并挂载 -v 宿主机目录:/app/data

# SQLAlchemy 是否打印每条 SQL（排障时 true）
# SQLALCHEMY_ECHO=false

# ---------- JWT ----------
# JWT_SECRET_KEY=请改为随机密钥
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# ---------- CORS ----------
# 前端开发时可为 http://localhost:5173；生产改为实际前端域名
# CORS_ORIGINS=["http://localhost:5173"]

# ---------- LLM（必配后对话/智能体才可用） ----------
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=

# ---------- LangSmith（可选） ----------
# LANGSMITH_TRACING=false
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=

# ---------- 作业并行度 ----------
# JOB_MAX_CONCURRENT_DEFAULT=3
# JOB_MAX_CONCURRENT_AGENT=
